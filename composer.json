{
  "name": "ez-php/http",
  "version": "0.5.1",
  "description": "HTTP message objects for the ez-php framework — immutable Request, Response, RequestFactory, and ResponseEmitter. Zero dependencies.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["http", "request", "response", "psr", "php"],
  "homepage": "https://github.com/ez-php/http",
  "support": {
    "issues": "https://github.com/ez-php/http/issues",
    "source": "https://github.com/ez-php/http"
  },
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "ez-php/docker": "0.*",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Http\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
